# Backend ortam değişkenleri — bu dosyayı .env olarak kopyalayıp doldurun.

# Prisma / SQLite veritabanı yolu
DATABASE_URL="file:./dev.db"

# JWT imzalama sırrı — ÜRETİMDE mutlaka güçlü ve gizli bir değer verin
JWT_SECRET="change-me"

# API portu
PORT=4000

# Üretimde CORS izin listesi (virgülle ayrılmış origin'ler). Boşsa dev'de tüm origin'lere açık.
ALLOWED_ORIGINS=

// Prisma şeması — dev: SQLite, prod: provider'ı "postgresql" yapıp DATABASE_URL değiştir.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model AdminUser {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  name         String
  passwordHash String
  role         String   // ik | mu | su
  createdAt    DateTime @default(now())
}

model Branch {
  id           Int        @id @default(autoincrement())
  name         String
  city         String?
  mode         String     @default("kiosk") // kiosk | hibrit | saha
  shift        String     @default("09:00 – 18:00")
  lat          Float?
  lng          Float?
  radius       Int        @default(100) // konum sınırı yarıçapı (metre)
  workingDays  String     @default("[1,2,3,4,5,6]") // haftalık açık günler (getDay(): Paz=0..Cmt=6); varsayılan Pzt–Cmt
  username     String?    @unique
  passwordHash String?
  managerPin   String?    // statik kiosk yönetici PIN'i (4-6 hane, düz metin — admin panelde görür/ayarlar)
  employees    Employee[]
  punches      Punch[]
  devices      Device[]
  createdAt    DateTime   @default(now())
}

model Device {
  id        Int      @id @default(autoincrement())
  branchId  Int
  branch    Branch   @relation(fields: [branchId], references: [id])
  code      String   @unique // TBL-xxxx
  label     String?  // kullanım yeri: Giriş, Fabrika, Kasa vb.
  status    String   @default("active") // active | revoked
  backup    Boolean  @default(false)
  punches   Punch[]
  createdAt DateTime @default(now())
}

model Shift {
  id        Int        @id @default(autoincrement())
  name      String
  start     String     // "09:00"
  end       String     // "18:00"
  overnight Boolean    @default(false)
  breakMin  Int        @default(60)
  employees Employee[]
  createdAt DateTime   @default(now())
}

model Employee {
  id           Int             @id @default(autoincrement())
  tc           String          @unique // TC kimlik no — giriş kimliği
  name         String
  phone        String?
  address      String?
  dept         String?
  role         String?
  sicil        String?
  passwordHash String
  status       String          @default("pending") // pending | active | offboarding
  isManager    Boolean         @default(false) // şube yetkilisi — günlük kiosk kodunu görür
  annualLeaveDays Int          @default(14) // yıllık izin hakkı (gün) — İş Kanunu kıdeme göre admin ayarlar
  startDate    DateTime?
  exitDate     DateTime?
  exitReason   String?
  avatar       String?         // profil fotoğrafı (data URL, base64) — kioskta okutmada görünür
  branchId     Int?
  branch       Branch?         @relation(fields: [branchId], references: [id])
  shiftId      Int?
  shift        Shift?          @relation(fields: [shiftId], references: [id])
  punches      Punch[]
  requests     Request[]
  consents     ConsentRecord[]
  dataRequests DataRequest[]
  evaluations  Evaluation[]
  createdAt    DateTime        @default(now())
}

// Yıllık performans karnesi (çalışan × yıl) — elle öznel yıldız puanları + otomatik devam skoru
model Evaluation {
  id         Int      @id @default(autoincrement())
  employeeId Int
  employee   Employee @relation(fields: [employeeId], references: [id])
  year       Int
  scores     String   @default("{}") // JSON: { "<critId>": 1..5 } (elle, öznel)
  note       String? // genel yorum
  status     String   @default("draft") // draft | published
  evaluator  String? // actor (audit)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([employeeId, year])
  @@index([year])
}

// Değerlendirme dönemi — İK belirler: tarih aralığı + kriter alt kümesi + hedef şube(ler).
// Aralık içindeyken şube yöneticisinin kioskunda görünür; yönetici birebir puanlar.
model EvalCampaign {
  id          Int                 @id @default(autoincrement())
  name        String
  year        Int
  startDate   String // YYYY-MM-DD
  endDate     String // YYYY-MM-DD (dahil)
  branchIds   String              @default("[]") // JSON [branchId,...]
  criteriaIds String              @default("[]") // JSON [critId,...] (manual alt küme)
  status      String              @default("active") // active | closed
  createdAt   DateTime            @default(now())
  entries     EvalCampaignEntry[]
}

// Yöneticinin kioskta bir çalışan için girdiği dönem puanları (dönem × çalışan).
model EvalCampaignEntry {
  id          Int          @id @default(autoincrement())
  campaignId  Int
  campaign    EvalCampaign @relation(fields: [campaignId], references: [id])
  employeeId  Int
  scores      String       @default("{}") // JSON { critId: 1..5 }
  note        String?
  evaluator   String? // 'Şube müdürü'
  submittedAt DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([campaignId, employeeId])
  @@index([campaignId])
}

model ConsentRecord {
  id         Int      @id @default(autoincrement())
  employeeId Int
  employee   Employee @relation(fields: [employeeId], references: [id])
  version    String
  acceptedAt DateTime @default(now())
}

model DataRequest {
  id         Int      @id @default(autoincrement())
  employeeId Int
  employee   Employee @relation(fields: [employeeId], references: [id])
  type       String   // access | rectify | erase
  note       String?
  status     String   @default("pending") // pending | done
  createdAt  DateTime @default(now())
}

model PayrollPeriod {
  id        Int       @id @default(autoincrement())
  month     String    @unique // "2026-06"
  status    String    @default("open") // open | closed
  closedAt  DateTime?
  createdAt DateTime  @default(now())
}

model Punch {
  id         Int      @id @default(autoincrement())
  employeeId Int
  employee   Employee @relation(fields: [employeeId], references: [id])
  branchId   Int
  branch     Branch   @relation(fields: [branchId], references: [id])
  deviceId   Int?     // hangi ekrandan/cihazdan okutuldu
  device     Device?  @relation(fields: [deviceId], references: [id])
  action     String   // enter | exit | break-out | break-in
  serverTime DateTime @default(now()) // otoritatif zaman damgası (çevrimdışı kuyrukta gerçek okutma anı)
  status     String   @default("ok")  // ok | review | confirmed (müdür onayladı)
  source     String   @default("qr")  // qr | manual | offline (çevrimdışı kuyruktan senkronlandı)
  clientId   String?  @unique          // çevrimdışı okutma idempotency anahtarı (tekrar gönderimde çift kayıt olmaz)
  createdAt  DateTime @default(now())

  @@index([employeeId, serverTime]) // puantaj sorguları (çalışan + dönem)
  @@index([branchId, serverTime])   // şube/gün raporları
}

model Request {
  id               Int       @id @default(autoincrement())
  employeeId       Int
  employee         Employee  @relation(fields: [employeeId], references: [id])
  kind             String    // leave | fix
  type             String
  detail           String?
  status           String    @default("pending") // pending | approved | rejected
  leaveStart       String?   // izin başlangıcı YYYY-MM-DD (kind=leave)
  leaveEnd         String?   // izin bitişi YYYY-MM-DD
  branchId         Int?      // talebi işleyecek şubenin müdürü
  stage            String    @default("manager") // manager | admin | done
  managerRec       String?   // approve | reject (müdür kararı/önerisi)
  managerNote      String?
  managerDecidedAt DateTime?
  createdAt        DateTime  @default(now())

  @@index([employeeId, status]) // çalışanın talepleri / bekleyenler
  @@index([branchId, status])   // şubeye düşen bekleyen talepler
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  actor     String
  kind      String
  action    String
  detail    String?
  createdAt DateTime @default(now())

  @@index([createdAt]) // son denetim kayıtları (sıralı)
}

model Setting {
  key   String @id
  value String // JSON
}

// İK'nın çalışanlara gönderdiği duyuru (uygulama-içi liste + banner + push tetikleyici)
model Announcement {
  id         Int      @id @default(autoincrement())
  title      String
  body       String
  audience   String   @default("all") // all | branch
  branchId   Int? // audience=branch ise hedef şube
  recipients Int      @default(0) // gönderim anındaki hedef çalışan sayısı (geçmiş için)
  active     Boolean  @default(true)
  createdBy  String?
  createdAt  DateTime @default(now())

  @@index([createdAt])
}

// Çalışan cihazının Expo push token'ı (gerçek bildirim için)
model PushToken {
  id         Int      @id @default(autoincrement())
  employeeId Int
  token      String   @unique // ExponentPushToken[...]
  platform   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([employeeId])
}

model Holiday {
  id               Int      @id @default(autoincrement())
  date             String   @unique // "YYYY-MM-DD"
  name             String // "Cumhuriyet Bayramı", "Kurban Bayramı 1. Gün"
  type             String // resmi | dini | custom
  workingBranchIds String   @default("[]") // o tatilde ÇALIŞACAK şube id'leri (JSON dizi); boş = tüm şubeler kapalı
  createdAt        DateTime @default(now())
}
